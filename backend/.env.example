# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL (Azure) ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/sportstock

# ── Clerk ────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Storage ─────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_STORAGE_BUCKET=sportstock-assets

# ── Firebase Cloud Messaging ─────────────────────────────────
FIREBASE_PROJECT_ID=sportstock-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sportstock-xxxxx.iam.gserviceaccount.com
# Paste the private key as a single line with \n for newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"
