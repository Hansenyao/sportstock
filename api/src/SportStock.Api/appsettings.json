{
  "Db": {
    "ConnectionString": ""
  },
  "Jwt": {
    "Secret": "",
    "ExpiresIn": "7d"
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": ""
  },
  "Firebase": {
    "ProjectId": "sportstock",
    "ClientEmail": "sportstock@gmail.com",
    "PrivateKey": "fake-firebase-api-key"
  },
  "Resend": {
    "ApiKey": "fake-resend-api-key",
    "FromEmail": "noreply@sportstock.com"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
