# SportStock .NET Backend - Environment Variable Template
#
# These keys mirror the structure of src/SportStock.Api/appsettings.json.
# Any env var set here overrides the corresponding appsettings entry.
# Section/key separator is "__" (two underscores) - .NET's standard convention
# for mapping flat env vars onto nested JSON config.
#
# Copy this file to .env.local (gitignored), or set the variables in your
# host environment / Azure App Service "Configuration" blade.

# ---- Database (Postgres) ----
Db__ConnectionString=Host=...;Port=5432;Database=sportstock;Username=...;Password=...;SslMode=Require

# ---- JWT signing ----
# IMPORTANT: must equal the Node backend's JWT_SECRET during cutover so tokens
# issued by either implementation validate on the other.
Jwt__Secret=replace-me-during-deployment
Jwt__ExpiresIn=7d

# ---- Cloudinary Storage ----
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=

# ---- Firebase Cloud Messaging ----
Firebase__ProjectId=
Firebase__ClientEmail=
# In Vercel / Azure App Service the private key is pasted as one line with
# the literal "\n" sequence between PEM lines. Program.cs normalizes those
# back to real newlines at startup.
Firebase__PrivateKey=

# ---- Resend (email delivery) ----
# Phase 0 ships StubEmailSender; these values are not actually used yet.
Resend__ApiKey=
Resend__FromEmail=noreply@sportstock.com

# ---- ASP.NET Core ----
ASPNETCORE_ENVIRONMENT=Development
# Override the dev port if 3000 is taken locally.
# ASPNETCORE_URLS=http://localhost:3000
