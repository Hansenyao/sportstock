{
  "Db": {
    "ConnectionString": ""
  },
  "Jwt": {
    "Secret": "",
    "ExpiresIn": "7d"
  },
  "Supabase": {
    "Url": "",
    "ServiceRoleKey": "",
    "Bucket": "sportstock-assets"
  },
  "Firebase": {
    "ProjectId": "",
    "ClientEmail": "",
    "PrivateKey": ""
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "noreply@sportstock.com"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
